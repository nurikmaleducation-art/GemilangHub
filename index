    "student-notes": ["Nota & Lampiran", "Akses bahan pembelajaran"],
    "student-quizzes": ["Latihan & Kuiz", "Jawab penilaian yang tersedia"],
    "student-results": ["Keputusan", "Semak markah anda"]
