function getCurrentUser() {
  return appState.users.find((user) => user.id === appState.currentUserId) || null;
}

function getTeacherClasses(teacherId) {
  return appState.classes.filter((classroom) => classroom.teacherId === teacherId);
}

function getStudentClasses(studentId) {
  const classIds = appState.enrollments.filter((entry) => entry.studentId === studentId).map((entry) => entry.classId);
  return appState.classes.filter((classroom) => classIds.includes(classroom.id));
}

function getStudentsInClass(classId) {
  const studentIds = appState.enrollments.filter((entry) => entry.classId === classId).map((entry) => entry.studentId);
  return appState.users.filter((user) => user.role === "student" && studentIds.includes(user.id));
}

function getTopicsForSelectedClass() {
  return appState.topics.filter((topic) => topic.classroomId === uiState.selectedClassId).sort((a, b) => a.order - b.order);
}

function getTopicById(topicId) {
  return appState.topics.find((topic) => topic.id === topicId);
}

function getClassroomById(classId) {
  return appState.classes.find((classroom) => classroom.id === classId);
}

function getQuizById(quizId) {
  return appState.quizzes.find((quiz) => quiz.id === quizId);
}

function getSubmission(quizId, studentId) {
  return appState.submissions.find((submission) => submission.quizId === quizId && submission.studentId === studentId);
}

function getTeacherQuizzes(teacherId) {
  const classIds = getTeacherClasses(teacherId).map((classroom) => classroom.id);
  const topicIds = appState.topics.filter((topic) => classIds.includes(topic.classroomId)).map((topic) => topic.id);
  return appState.quizzes.filter((quiz) => topicIds.includes(quiz.topicId));
}

function calculateTeacherMetrics(teacherId) {
  const quizzes = getTeacherQuizzes(teacherId);
  const students = getTeacherClasses(teacherId).flatMap((classroom) => getStudentsInClass(classroom.id));
  const uniqueStudents = [...new Set(students.map((student) => student.id))];
  const submissions = appState.submissions.filter((submission) => quizzes.some((quiz) => quiz.id === submission.quizId));
  const totalPossible = quizzes.length * uniqueStudents.length;
  const averageScore = submissions.length ? Math.round(submissions.reduce((sum, item) => sum + scoreToPercent(item.quizId, item.mark), 0) / submissions.length) : 0;
  const completionRate = totalPossible ? Math.round((submissions.length / totalPossible) * 100) : 0;
  return { averageScore, completionRate };
}

function getActiveQuizzesForTeacher(teacherId) {
  return getTeacherQuizzes(teacherId)
    .filter((quiz) => getQuizAvailability(quiz) === "open")
    .map((quiz) => {
      const topic = getTopicById(quiz.topicId);
      const classroom = topic ? getClassroomById(topic.classroomId) : null;
      return {
        quiz,
        topic,
        classroom,
        studentCount: classroom ? getStudentsInClass(classroom.id).length : 0,
        submissionCount: appState.submissions.filter((submission) => submission.quizId === quiz.id).length
      };
    });
}

function getLateStudentsForTeacher(teacherId) {
  return getActiveQuizzesForTeacher(teacherId).flatMap((entry) =>
    getStudentsInClass(entry.classroom.id)
      .filter((student) => !getSubmission(entry.quiz.id, student.id))
      .map((student) => ({ ...entry, student }))
  );
}

function getStudentMaterials(studentId) {
  const classIds = getStudentClasses(studentId).map((classroom) => classroom.id);
  const topicIds = appState.topics.filter((topic) => classIds.includes(topic.classroomId)).map((topic) => topic.id);
  return appState.materials.filter((material) => topicIds.includes(material.topicId));
}

function getRecentMaterialsForStudent(studentId) {
  return getStudentMaterials(studentId).sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt)).slice(0, 4);
}

function getStudentAvailableQuizzes(studentId) {
  return getStudentClasses(studentId).flatMap((classroom) =>
    appState.topics.filter((topic) => topic.classroomId === classroom.id).flatMap((topic) =>
      appState.quizzes.filter((quiz) => quiz.topicId === topic.id).map((quiz) => ({ classroom, topic, quiz }))
    )
  );
}

function getPendingQuizzesForStudent(studentId) {
  return getStudentAvailableQuizzes(studentId)
    .filter((entry) => getQuizAvailability(entry.quiz) === "open")
    .filter((entry) => !getSubmission(entry.quiz.id, studentId));
}

function studentCanAccessQuiz(studentId, quizId) {
  return getStudentAvailableQuizzes(studentId).some((entry) => entry.quiz.id === quizId);
}

function getQuizAvailability(quiz) {
  const now = new Date();
  const openAt = new Date(quiz.openAt);
  const closeAt = new Date(quiz.closeAt);
  if (now < openAt) return "upcoming";
  if (now > closeAt) return "closed";
  return "open";
}

function scoreToPercent(quizId, mark) {
  const quiz = getQuizById(quizId);
  return quiz?.fullMark ? Math.round((mark / quiz.fullMark) * 100) : 0;
}

function createId(prefix) {
  return `${prefix}-${Math.random().toString(36).slice(2, 10)}`;
}

function formatDate(value) {
  return value ? new Date(value).toLocaleDateString("ms-MY", { day: "numeric", month: "short", year: "numeric" }) : "-";
}

function formatDateTime(value) {
  return value
    ? new Date(value).toLocaleString("ms-MY", { day: "numeric", month: "short", year: "numeric", hour: "2-digit", minute: "2-digit" })
    : "-";
}

function capitalize(value) {
  return value.charAt(0).toUpperCase() + value.slice(1);
}

function readFileAsDataUrl(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = () => resolve(reader.result);
    reader.onerror = reject;
    reader.readAsDataURL(file);
  });
}

function inferFileType(fileName) {
  const lower = fileName.toLowerCase();
  if (lower.endsWith(".pdf")) return "application/pdf";
  if (lower.endsWith(".doc")) return "application/msword";
  if (lower.endsWith(".docx")) return "application/vnd.openxmlformats-officedocument.wordprocessingml.document";
  return "application/octet-stream";
}
