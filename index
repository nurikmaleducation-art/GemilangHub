  const selectedTopicId = uiState.selectedTopicId || topics[0]?.id || "";
  const materials = appState.materials.filter((item) => item.topicId === selectedTopicId);

  appEl.innerHTML = `
    <div class="grid two">
      <section class="panel">
        <div class="panel-head"><div><p class="eyebrow">Pilih konteks</p><h3 class="section-title">Topik kelas</h3></div></div>
