function renderStudentQuizzes(currentUser) {
  const selectedQuiz = uiState.selectedQuizId ? getQuizById(uiState.selectedQuizId) : null;
  const pending = getPendingQuizzesForStudent(currentUser.id);
  const submittedQuizIds = appState.submissions.filter((submission) => submission.studentId === currentUser.id).map((submission) => submission.quizId);

  if (selectedQuiz) {
    if (!studentCanAccessQuiz(currentUser.id, selectedQuiz.id)) {
      uiState.selectedQuizId = null;
      return render();
    }

    const questions = appState.questions.filter((question) => question.quizId === selectedQuiz.id);
    const submission = getSubmission(selectedQuiz.id, currentUser.id);
    const status = getQuizAvailability(selectedQuiz);

    appEl.innerHTML = `
      <section class="panel">
        <div class="panel-head"><div><p class="eyebrow">Menjawab kuiz</p><h3 class="section-title">${selectedQuiz.title}</h3></div><button class="ghost" id="backToQuizList" type="button">Kembali</button></div>
        <p class="muted">${getTopicById(selectedQuiz.topicId)?.title || "-"} · Markah penuh ${selectedQuiz.fullMark}</p>
        <div class="action-row">${renderStatusBadgeLabel(status)} ${submission ? '<span class="badge success">Sudah dihantar</span>' : ""}</div>
        ${questions.length ? `
        <form id="studentQuizForm" class="stack">
          ${questions.map((question, index) => `
            <article class="question-card">
              <strong>Soalan ${index + 1}</strong>
              <p>${question.stem}</p>
              <div class="choice-list">
                ${question.options.map((option, optionIndex) => `
                  <label class="choice-option">
                    <input type="radio" name="question-${question.id}" value="${optionIndex}" ${submission && submission.answers[index] === optionIndex ? "checked" : ""} ${submission ? "disabled" : ""} required />
                    <span>${option}</span>
                  </label>
                `).join("")}
              </div>
            </article>
          `).join("")}
          ${submission ? `<div class="notice">Markah anda: ${submission.mark}/${selectedQuiz.fullMark} (${scoreToPercent(selectedQuiz.id, submission.mark)}%)</div>` : status === "closed" ? `<div class="notice">Kuiz ini sudah ditutup dan tidak boleh dihantar lagi.</div>` : `<button class="primary" type="submit">Hantar jawapan</button>`}
        </form>` : '<div class="empty">Kuiz ini belum mempunyai soalan.</div>'}
      </section>
    `;

    document.getElementById("backToQuizList").addEventListener("click", () => {
      uiState.selectedQuizId = null;
      render();
    });

    if (!submission && questions.length && status !== "closed") {
      document.getElementById("studentQuizForm").addEventListener("submit", (event) => {
        event.preventDefault();
        const data = new FormData(event.currentTarget);
        const answers = questions.map((question) => Number(data.get(`question-${question.id}`)));
        if (answers.some((value) => Number.isNaN(value))) return alert("Sila jawab semua soalan.");

        const mark = questions.reduce((sum, question, index) => sum + (answers[index] === question.correctAnswer ? question.mark : 0), 0);
        appState.submissions.push({
          id: createId("s"),
          quizId: selectedQuiz.id,
          studentId: currentUser.id,
          answers,
          mark,
          status: "submitted",
          submittedAt: new Date().toISOString()
        });
        saveState();
        render();
      });
    }
    return;
  }

  appEl.innerHTML = `
    <section class="panel">
      <div class="panel-head"><div><p class="eyebrow">Senarai kuiz</p><h3 class="section-title">Aktiviti untuk anda</h3></div></div>
      <div class="quiz-list">
        ${getStudentAvailableQuizzes(currentUser.id).map((entry) => `
          <article class="quiz-card">
            <h4>${entry.quiz.title}</h4>
            <p class="muted">${entry.classroom.name} · ${entry.topic.title}</p>
            <div class="action-row">${renderStatusBadgeLabel(getQuizAvailability(entry.quiz))} ${submittedQuizIds.includes(entry.quiz.id) ? '<span class="badge success">Sudah dihantar</span>' : ""}</div>
            <div class="action-row"><span class="muted">Tutup ${formatDate(entry.quiz.closeAt)}</span><button class="soft" data-open-quiz="${entry.quiz.id}" type="button">${submittedQuizIds.includes(entry.quiz.id) ? "Lihat jawapan" : "Jawab kuiz"}</button></div>
          </article>
        `).join("") || '<div class="empty">Tiada kuiz tersedia setakat ini.</div>'}
      </div>
      ${pending.length ? '<p class="notice">Ada kuiz aktif yang masih belum anda hantar.</p>' : ""}
    </section>
  `;

  bindOpenQuizButtons();
}

