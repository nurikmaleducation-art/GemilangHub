function renderPage(currentUser) {
  if (!currentUser) return renderLogin();
  if (currentUser.role === "teacher") return renderTeacherPage(currentUser);
  return renderStudentPage(currentUser);
}

function renderLogin() {
  const template = document.getElementById("loginTemplate");
  appEl.innerHTML = "";
  appEl.appendChild(template.content.cloneNode(true));

  const demoAccountsEl = document.getElementById("demoAccounts");
  demoAccountsEl.innerHTML = appState.users
    .map((user) => `<button class="soft" data-demo="${user.id}" type="button">${user.name}<br /><span class="muted">${user.email}</span></button>`)
    .join("");

  demoAccountsEl.querySelectorAll("[data-demo]").forEach((button) => {
    button.addEventListener("click", () => loginAs(button.dataset.demo));
  });

  document.getElementById("loginForm").addEventListener("submit", (event) => {
    event.preventDefault();
    const email = new FormData(event.currentTarget).get("email").toString().trim().toLowerCase();
    const user = appState.users.find((entry) => entry.email.toLowerCase() === email);
    if (!user) return alert("Emel tidak ditemui. Gunakan akaun demo atau daftar akaun baharu.");
    loginAs(user.id);
  });

  document.getElementById("registerForm").addEventListener("submit", (event) => {
    event.preventDefault();
    const data = new FormData(event.currentTarget);
    const email = data.get("email").toString().trim().toLowerCase();
    if (appState.users.some((user) => user.email.toLowerCase() === email)) return alert("Emel ini sudah digunakan.");

    const user = {
      id: createId("u"),
      name: data.get("name").toString().trim(),
      email,
      role: data.get("role").toString()
    };
    appState.users.push(user);
    saveState();
    loginAs(user.id);
  });
}

function loginAs(userId) {
  appState.currentUserId = userId;
  const currentUser = getCurrentUser();
  uiState.page = currentUser.role === "teacher" ? "teacher-dashboard" : "student-home";
  saveState();
  render();
}

function renderTeacherPage(currentUser) {
  if (uiState.page === "teacher-classes") return renderTeacherClasses(currentUser);
  if (uiState.page === "teacher-content") return renderTeacherContent(currentUser);
  if (uiState.page === "teacher-quizzes") return renderTeacherQuizzes(currentUser);
  if (uiState.page === "teacher-performance") return renderTeacherPerformance(currentUser);
  renderTeacherDashboard(currentUser);
}

function renderStudentPage(currentUser) {
  if (uiState.page === "student-classes") return renderStudentClasses(currentUser);
  if (uiState.page === "student-notes") return renderStudentNotes(currentUser);
  if (uiState.page === "student-quizzes") return renderStudentQuizzes(currentUser);
  if (uiState.page === "student-results") return renderStudentResults(currentUser);
  renderStudentHome(currentUser);
}

