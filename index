function loadState() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return structuredClone(seedState);
    return { ...structuredClone(seedState), ...JSON.parse(raw) };
  } catch (error) {
    console.error("Gagal membaca storan tempatan", error);
    return structuredClone(seedState);
  }
}

function saveState() {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(appState));
}

function render() {
  const currentUser = getCurrentUser();
  syncSelections();
  renderNavigation(currentUser);
  renderShell(currentUser);
  renderPage(currentUser);
}

function syncSelections() {
  if (!uiState.selectedClassId && appState.classes.length) {
    uiState.selectedClassId = appState.classes[0].id;
  }
  const topics = getTopicsForSelectedClass();
  if (!topics.find((topic) => topic.id === uiState.selectedTopicId)) {
    uiState.selectedTopicId = topics[0]?.id || null;
  }
}

function renderNavigation(currentUser) {
  if (!currentUser) {
    navEl.innerHTML = "";
    logoutButton.classList.add("hidden");
    sessionSummaryEl.textContent = "Sila log masuk untuk mula.";
    return;
  }

  navEl.innerHTML = navByRole[currentUser.role]
    .map((item) => `<button class="${uiState.page === item.id ? "active" : ""}" data-nav="${item.id}" type="button">${item.label}</button>`)
    .join("");

  navEl.querySelectorAll("[data-nav]").forEach((button) => {
    button.addEventListener("click", () => {
      uiState.page = button.dataset.nav;
      uiState.selectedQuizId = null;
      render();
    });
  });

  logoutButton.classList.remove("hidden");
  sessionSummaryEl.textContent = `${currentUser.name} · ${currentUser.role === "teacher" ? "Guru" : "Murid"}`;
}

function renderShell(currentUser) {
  if (!currentUser) {
    pageTitleEl.textContent = "Selamat datang";
