          <label>Tajuk topik<input name="title" type="text" placeholder="Bab 3: Wang dan Bank" required /></label>
          <label>Turutan<input name="order" type="number" min="1" value="${topics.length + 1}" required /></label>
          <button class="primary" type="submit">Tambah topik</button>
        </form>
      </section>
    </div>
    <div class="grid two">
      <section class="panel">
        <div class="panel-head"><div><p class="eyebrow">Muat naik bahan</p><h3 class="section-title">Lampiran nota / latihan</h3></div></div>
        <form id="materialForm" class="stack">
          <label>Jenis bahan<select name="type"><option value="nota">Nota</option><option value="latihan">Latihan</option><option value="lampiran">Lampiran soalan</option></select></label>
          <label>Tajuk bahan<input name="title" type="text" placeholder="Nota Bab 3" required /></label>
          <label>Fail PDF / DOC / DOCX<input name="file" type="file" accept=".pdf,.doc,.docx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document" required /></label>
          <p class="notice">Saiz fail maksimum untuk simpanan tempatan ialah 3MB.</p>
          <button class="ghost" type="submit">Simpan bahan</button>
        </form>
      </section>
      <section class="panel">
        <div class="panel-head"><div><p class="eyebrow">Bahan mengikut topik</p><h3 class="section-title">Senarai lampiran</h3></div></div>
        <div class="list">${materials.map(renderMaterialCard).join("") || '<div class="empty">Belum ada bahan dalam topik ini.</div>'}</div>
      </section>
    </div>
  `;

  document.getElementById("teacherContentClass").addEventListener("change", (event) => {
    uiState.selectedClassId = event.target.value;
    uiState.selectedTopicId = appState.topics.filter((topic) => topic.classroomId === uiState.selectedClassId).sort((a, b) => a.order - b.order)[0]?.id || null;
    render();
  });

  document.getElementById("teacherContentTopic").addEventListener("change", (event) => {
    uiState.selectedTopicId = event.target.value;
    render();
  });

  document.getElementById("topicForm").addEventListener("submit", (event) => {
    event.preventDefault();
    const data = new FormData(event.currentTarget);
    const topic = { id: createId("t"), classroomId: selectedClassId, title: data.get("title").toString().trim(), order: Number(data.get("order")) };
    appState.topics.push(topic);
    uiState.selectedTopicId = topic.id;
    saveState();
    render();
  });

  document.getElementById("materialForm").addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!selectedTopicId) return alert("Tambah topik dahulu sebelum muat naik bahan.");
    const data = new FormData(event.currentTarget);
    const file = data.get("file");
    if (!(file instanceof File) || !file.name) return alert("Sila pilih fail yang sah.");
    if (file.size > 3 * 1024 * 1024) return alert("Fail terlalu besar untuk storan tempatan. Gunakan fail 3MB ke bawah.");

    const fileData = await readFileAsDataUrl(file);
    appState.materials.push({
      id: createId("m"),
      topicId: selectedTopicId,
      type: data.get("type").toString(),
      title: data.get("title").toString().trim(),
      fileName: file.name,
      fileType: file.type || inferFileType(file.name),
      fileData,
      fileSize: file.size,
      ownerId: currentUser.id,
      createdAt: new Date().toISOString()
    });
    saveState();
    render();
  });

  bindMaterialDownloads();
}

