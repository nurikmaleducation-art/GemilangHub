  document.getElementById("quizForm").addEventListener("submit", (event) => {
    event.preventDefault();
    if (!uiState.selectedTopicId) return alert("Pilih atau cipta topik dahulu.");
    const data = new FormData(event.currentTarget);
    const questionDefs = [1, 2].map((index) => ({
      stem: data.get(`stem${index}`).toString().trim(),
      options: data.get(`options${index}`).toString().split("|").map((item) => item.trim()).filter(Boolean),
      correctAnswer: Number(data.get(`answer${index}`)) - 1
    }));

    if (questionDefs.some((question) => question.options.length < 2)) {
      return alert("Setiap soalan perlu sekurang-kurangnya dua pilihan jawapan.");
    }

    const quizId = createId("q");
    appState.quizzes.push({
      id: quizId,
      topicId: uiState.selectedTopicId,
      title: data.get("title").toString().trim(),
      status: "published",
      openAt: data.get("openAt").toString(),
      closeAt: data.get("closeAt").toString(),
      fullMark: questionDefs.length * 5
    });

    questionDefs.forEach((question) => {
      appState.questions.push({
        id: createId("qq"),
        quizId,
        type: "mcq",
        stem: question.stem,
        options: question.options,
        correctAnswer: question.correctAnswer,
        mark: 5
      });
    });

    saveState();
    render();
  });
}

